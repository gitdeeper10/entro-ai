# ENTROPIA Environment Variables
# Thermodynamic Framework for Digital Systems
# E-LAB-01 v1.0.0

# Application Settings
ENTROPIA_ENV=production
ENTROPIA_DEBUG=false
ENTROPIA_LOG_LEVEL=INFO

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_REFRESH_MS=3000

# System Parameters
ENTROPIA_ARCHITECTURE=von_neumann
ENTROPIA_NODE_COUNT=1000000
ENTROPIA_BANDWIDTH=1e12

# Critical Thresholds
ENTROPIA_CRITICAL_PSI=2.0
ENTROPIA_CRITICAL_RHO_RATIO=0.95
ENTROPIA_COLLAPSE_LEAD_TIME_MIN=30

# Thermodynamic Parameters
ENTROPIA_ALPHA=0.85
ENTROPIA_BETA=0.15
ENTROPIA_SCALING_EXPONENT=1.85
ENTROPIA_ACTIVATION_ENERGY=0.6

# Simulation Settings
ENTROPIA_SIMULATION_SEED=42
ENTROPIA_SIMULATION_TIMESTEP=0.001
ENTROPIA_SIMULATION_DURATION=3600

# Data Directories
ENTROPIA_DATA_DIR=../data
ENTROPIA_REPORTS_DIR=../reports
ENTROPIA_OUTAGE_DATA_DIR=../data/case_studies
