# ENTRO-AI Environment Configuration
# Entropy-Resistant Inference Architecture for LLMs

# Application Settings
ENTRO_AI_ENV=development
ENTRO_AI_DEBUG=true
ENTRO_AI_LOG_LEVEL=INFO

# Dashboard Configuration
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080
DASHBOARD_DEBUG=false

# AI Model Parameters
ENTRO_AI_ARCHITECTURE=transformer_llm  # transformer_llm | bert | vit | neuromorphic
ENTRO_AI_MODEL_SIZE=7b  # 7b, 13b, 70b
ENTRO_AI_CONTEXT_LENGTH=8192  # tokens
ENTRO_AI_LAYERS=32
ENTRO_AI_D_MODEL=4096

# Hardware Constraints (GPU)
KV_CACHE_MEMORY_GB=40.0
GPU_MEMORY_BANDWIDTH_TBS=3.35  # H100 SXM5
ATTN_COMPUTE_BANDWIDTH_TFLOPS=1979  # H100 TFLOPS

# Critical Thresholds (from ENTROPIA E-LAB-01)
ENTRO_AI_CRITICAL_PSI=2.0
ENTRO_AI_CRITICAL_RHO_RATIO=0.95
ENTRO_AI_COLLAPSE_LEAD_TIME_MIN=30  # seconds

# Architecture-Specific Exponents (n)
ENTRO_AI_SCALING_EXPONENT=1.63  # Transformer LLM
ENTRO_AI_ACTIVATION_EV=0.58  # eV for transformer

# EDT Controller Settings
EDT_L1_THRESHOLD=1.5   # Soft - Reduce batch size
EDT_L2_THRESHOLD=1.7   # Medium - INT8 quantization
EDT_L3_THRESHOLD=1.85  # Hard - Route to smaller model
EDT_L4_THRESHOLD=2.0   # Critical - Graceful shutdown
EDT_UPDATE_INTERVAL_MS=10

# Intervention Efficacy (η_EDT)
EDT_ETA_L1=0.31
EDT_ETA_L2=0.47
EDT_ETA_L3=0.68

# Telemetry Adapters
VLLM_ENDPOINT=http://localhost:8000
TENSORRT_ENDPOINT=http://localhost:8001
TRITON_ENDPOINT=http://localhost:8002

# Data Directories
ENTRO_AI_DATA_DIR=/home/entro-ai/data
ENTRO_AI_CALIBRATION_DIR=/home/entro-ai/calibration
ENTRO_AI_CASE_STUDIES_DIR=/home/entro-ai/case_studies

# Builds on ENTROPIA (E-LAB-01)
ENTROPIA_DOI=10.5281/zenodo.19416737
ENTROPIA_WEBSITE=https://entropia-lab.netlify.app

# API Keys (optional)
# OPENAI_API_KEY=your_key_here
# ANTHROPIC_API_KEY=your_key_here
# GOOGLE_API_KEY=your_key_here

# Monitoring
ENTRO_AI_METRICS_ENABLED=true
ENTRO_AI_METRICS_PORT=9090
ENTRO_AI_PROFILING_ENABLED=false

# Security
ENTRO_AI_SECRET_KEY=change_this_in_production
ENTRO_AI_ALLOWED_ORIGINS=http://localhost:8080,https://entropia-lab.netlify.app

# Notifications
ENTRO_AI_ALERT_WEBHOOK_URL=
ENTRO_AI_ALERT_EMAIL=admin@example.com

# Output Coherence Parameters
ENTRO_AI_QUALITY_METRIC=bertscore  # bertscore | rouge_l | bleu
ENTRO_AI_COHERENCE_THRESHOLD=0.12  # κ_min for context collapse
